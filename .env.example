# === Required ===
AWS_DEFAULT_REGION=us-east-1
PINECONE_INDEX_NAME=sherpa
PINECONE_API_KEY=
DYNAMODB_TABLE_NAME=sherpa
S3_BUCKET_NAME=sherpa-docs-YOUR_ACCOUNT_ID

# Slack
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# === Optional (defaults shown) ===

# RAG
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MIN_CONFIDENCE=0.3
MAX_CHUNKS=10

# Gemini
GEMINI_API_KEY=

# LLM (Gemini model IDs)
REASONING_MODEL_ID=gemini-2.5-flash-lite
GENERATION_MODEL_ID=gemini-2.5-flash

# Per-Turn Budget (Layer 1)
MAX_REASONING_CALLS_PER_TURN=3
MAX_GENERATION_CALLS_PER_TURN=1
MAX_TOOL_CALLS_PER_TURN=4
MAX_TOTAL_OUTPUT_TOKENS_PER_TURN=5000

# Per-User Daily Budget (Layer 2)
MAX_TURNS_PER_DAY=50
MAX_OUTPUT_TOKENS_PER_DAY=50000
MAX_TOOL_CALLS_PER_DAY=100

# Per-Workspace Monthly Budget (Layer 3)
MAX_WORKSPACE_MONTHLY_COST=5.0
MAX_WORKSPACE_MONTHLY_TOKENS=500000

# Kill Switch
KILL_SWITCH_THRESHOLD=5.0
KILL_SWITCH_CACHE_TTL_SECONDS=60

# Agent Worker
AGENT_WORKER_RESERVED_CONCURRENCY=5
SQS_VISIBILITY_TIMEOUT=900
